NODE_ENV=development
PORT=5000
SKIP_DB_CONNECT=false
APP_BASE_URL=http://localhost:3000
SERVE_FRONTEND=false
FRONTEND_BUILD_DIR=../frontend/build
FILE_STORAGE_ROOT=./storage

# MongoDB
MONGO_URI=mongodb+srv://agastyachowdary2_db_user:Agastya.27venu@mo.sje3f4u.mongodb.net/wevaluecrm?retryWrites=true&w=majority
# Optional but recommended when Atlas DB casing matters (example: restaurantCRM)
MONGO_DB_NAME=wevaluecrm

# Auth
JWT_SECRET=replace_with_a_long_random_secret
ACCESS_TOKEN_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d
AUTH_ACCESS_COOKIE_NAME=token
AUTH_REFRESH_COOKIE_NAME=wevalue_refresh
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=none
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
AUTH_RETURN_TOKENS_IN_BODY=false
REQUIRE_EMAIL_VERIFICATION=false
AUTH_INCLUDE_DEV_VERIFICATION_TOKEN=false
AUTH_ALLOW_QUICK_LOGIN=false
AUTH_ALLOW_INSECURE_PASSWORD_RESET=false
AUTH_ALLOW_DECODED_GOOGLE_LOGIN=false
ONBOARDING_OTP_INCLUDE_DEV_CODE=false

# Login OTP
LOGIN_OTP_ENABLED=false
LOGIN_OTP_TTL_MINUTES=10
LOGIN_OTP_MAX_ATTEMPTS=5
LOGIN_OTP_INCLUDE_DEV_CODE=false

# CORS
# Use your public CRM domain in production.
CORS_ORIGIN=https://wevalue.in,https://www.wevalue.in

# Verification URL
AUTH_VERIFICATION_BASE_URL=https://crm.yourdomain.com/verify-email
AUTH_EMAIL_VERIFY_URL_TEMPLATE=

# Resend (Email Delivery)
RESEND_API_KEY=re_********************************
RESEND_FROM_EMAIL=CRM <no-reply@yourdomain.com>
RESEND_REPLY_TO_EMAIL=support@yourdomain.com

# Twilio (SMS Delivery)
TWILIO_ACCOUNT_SID=AC********************************
TWILIO_AUTH_TOKEN=********************************
TWILIO_FROM_PHONE=+1415XXXXXXX

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
VERIFY_TOKEN=
# Optional override for multi-tenant deployments
WHATSAPP_RESTAURANT_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional webhook fallbacks
AUTH_EMAIL_HOOK_URL=
AUTH_EMAIL_HOOK_AUTH=
AUTH_EMAIL_HOOK_VERBOSE=false
AUTH_LOGIN_OTP_HOOK_URL=
AUTH_LOGIN_OTP_HOOK_AUTH=
AUTH_LOGIN_OTP_HOOK_VERBOSE=false

# Optional SMS API for onboarding OTP delivery
SMS_API_URL=
SMS_API_KEY=
SMS_API_AUTH_TOKEN=
SMS_SENDER_ID=
SMS_OTP_TEMPLATE=Your WeValue verification code is {{OTP}}

# Stripe (Optional Billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
# Legacy alias supported for backward compatibility:
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_CHECKOUT_SUCCESS_URL=https://crm.yourdomain.com/subscription?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=https://crm.yourdomain.com/subscription?checkout=cancel
STRIPE_PORTAL_RETURN_URL=https://crm.yourdomain.com/subscription

# Geocoding (Customer CRM map intelligence)
GEOCODING_DISABLED=false
GEOCODING_USER_AGENT=WeValueCRM/1.0 (ops@yourdomain.com)
GEOCODING_NOMINATIM_BASE_URL=
GEOCODING_MAPSCO_BASE_URL=
GEOCODING_MAPSCO_API_KEY=

# Optional super admin access
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_API_KEY=

# Optional Google login readiness
# Google login route remains disabled in production unless signed token verification
# is implemented and the frontend is wired to Google Identity Services.
GOOGLE_CLIENT_ID=
